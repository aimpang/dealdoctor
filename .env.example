# DealDoctor environment variables — copy to .env.local and fill in real values.
# Never commit .env.local or any file with real secrets.

# ---- Core ---------------------------------------------------------------
# Postgres connection string (Railway / Supabase / local). Must be reachable
# at build+runtime — Prisma Client talks to it directly.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Public origin used in emails, share links, JSON-LD, OG tags, and sitemap.
# No trailing slash.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# "development" | "production" | "test". Gates debug routes and dev bypasses.
NODE_ENV=development

# ---- AI / Data ----------------------------------------------------------
# Anthropic API key — powers Deal Doctor narrative and photo analysis.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Rentcast (PropertyAPI) key — property lookup + rent estimate.
PROPERTY_API_KEY=

# Mapbox token for maps and neighborhood signals. Safe to expose to browser.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# ---- Payments (LemonSqueezy) -------------------------------------------
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_SINGLE=
LEMONSQUEEZY_VARIANT_5PACK=
LEMONSQUEEZY_VARIANT_UNLIMITED=

# Webhook signing secret — set to the exact value configured in the
# LemonSqueezy webhook dashboard. No webhooks process without this.
LEMONSQUEEZY_WEBHOOK_SECRET=

# ---- Email (Resend) ----------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=DealDoctor <onboarding@resend.dev>
EMAIL_REPLY_TO=support@dealdoctor.com

# ---- Security ----------------------------------------------------------
# HMAC secret for share links (/report/<uuid>?t=<token>). Must be set in
# production — lib/shareToken.ts throws at module load if missing.
# Generate: openssl rand -hex 32
SHARE_LINK_SECRET=

# Gate for /api/admin/* routes. Sent via `X-Admin-Key` header.
ADMIN_KEY=

# Secondary gate for dev debug bypass (?debug=1&debugKey=...). Only honored
# when NODE_ENV !== 'production'.
DEBUG_ACCESS_SECRET=
