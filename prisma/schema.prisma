generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Buyers of single/5-pack/unlimited tiers. Email-keyed, no auth required.
// An opaque accessToken (random 32 bytes hex) is the "session" identifier —
// we set it as a cookie so subsequent /api/preview calls on the same browser
// can auto-pay reports against the customer's remaining quota. The same token
// also backs the magic-link recovery flow: users lose their URL, enter their
// email, we email them a link that re-sets the cookie on any device.
model Customer {
  id                      String    @id @default(cuid())
  email                   String    @unique
  accessToken             String    @unique
  // Short alphanumeric code (e.g., "DD-X7K2-A9PQ") shown on the purchase
  // success page so buyers who lose their email can still restore access by
  // pasting the code at /retrieve. The magic-link flow stays the primary
  // recovery path; this is the fallback for buyers who can't find the email.
  recoveryCode            String?   @unique
  entitlementType         String?   // 'single' | '5pack' | 'unlimited'
  reportsRemaining        Int       @default(0)    // for 5-pack
  unlimitedUntil          DateTime?                  // for unlimited subscription
  lemonSqueezyCustomerId  String?
  lemonSqueezySubscriptionId String?
  subscriptionStatus      String?   // 'active' | 'cancelled' | 'expired'
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  reports                 Report[]

  @@index([accessToken])
  @@index([recoveryCode])
}

// LemonSqueezy webhook deduplication. Each delivered event carries a unique
// ID we record here before processing. Unique constraint ensures a replayed
// event (LS retries on non-2xx) is rejected at insert, not by the processor.
// Without this, a replayed `order_created` would re-run generateFullReport
// and re-credit entitlements.
model WebhookEvent {
  id              String   @id @default(cuid())
  providerEventId String   @unique      // LemonSqueezy's event ID
  eventName       String                 // 'order_created', 'subscription_cancelled', etc.
  processedAt     DateTime @default(now())

  @@index([providerEventId])
}

// Feedback on a specific report. Users click thumbs-up/off after viewing.
// addressKey is a normalized form of the address (uppercase, non-alphanumeric
// stripped) so we can aggregate across MULTIPLE reports for the same property
// and surface "other buyers flagged this" warnings on future generations.
model ReportFeedback {
  id           String   @id @default(cuid())
  reportId     String
  addressKey   String   // normalized; indexed for cross-report aggregation
  verdict      String   // 'ok' | 'value_off' | 'rent_off' | 'both_off'
  customerId   String?
  submittedAt  DateTime @default(now())

  report       Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([addressKey, verdict])
}

// Periodic accuracy backtests. Each run samples N historical reports, pulls
// current Rentcast data for those addresses, compares what we predicted vs
// what shows up now. Stored so /methodology can display the latest numbers.
model BacktestRun {
  id              String    @id @default(cuid())
  runAt           DateTime  @default(now())
  sampleSize      Int
  valueMedianErr  Float?    // median absolute % error of value predictions
  valueWithin10   Float?    // fraction of predictions within 10% of current AVM
  rentMedianErr   Float?
  rentWithin10    Float?
  notes           String?
}

model Report {
  id              String   @id @default(uuid())
  address         String
  city            String
  state           String
  zipCode         String
  country         String   @default("US")
  feedback        ReportFeedback[]

  // Link back to the customer whose entitlement paid for this report.
  // Null for reports that haven't been paid yet (or were paid before the
  // customer system existed, pre-2026-04-13 migration).
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  // Teaser data (generated free)
  teaserData      String?  // JSON: {estimatedValue, estimatedRent, neighbourhoodScore}

  // User-supplied deal inputs (captured before paywall via /api/refine)
  offerPrice      Int?     // User's actual offer (not listing); defaults to estimatedValue
  downPaymentPct  Float?   // 0.20 for 20%
  rehabBudget     Int?     // Upfront rehab/repairs capital
  strategy        String?  // LTR | STR | FLIP — stored; only LTR processed today
  refinedAt       DateTime?

  // Full report (generated on payment)
  fullReportData  String?  // JSON: full analysis

  // Post-payment photo analysis (Gemini Vision)
  photoFindings    String?   // JSON: { photos: [{ index, findings: [...] }] }
  photosAnalyzedAt DateTime?

  // Payment
  paid            Boolean  @default(false)
  paymentOrderId  String?  // LemonSqueezy order ID
  customerEmail   String?
  paidAt          DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
